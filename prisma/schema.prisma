generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  PROVIDER
  ADMIN
}

enum ProviderTier {
  RABBI
  SCHOLAR
  SPECIALIST
}

enum ProviderStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Denomination {
  ORTHODOX
  CONSERVATIVE
  REFORM
  RECONSTRUCTIONIST
  RENEWAL
  PLURALISTIC
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  CRISIS_BLOCKED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(USER)
  timezone     String    @default("America/New_York")
  gender       Gender?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  provider     Provider?
  bookings     Booking[]
  betaSignup   BetaSignup?
}

model Provider {
  id               String         @id @default(cuid())
  userId           String         @unique
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug             String         @unique
  title            String
  bio              String
  denomination     Denomination
  ordinationBody   String?
  tier             ProviderTier
  status           ProviderStatus @default(PENDING)
  gender           Gender
  languages        String
  specialties      String
  timezone         String         @default("America/New_York")
  photoUrl         String?
  stripeAccountId  String?
  meetingLink      String?
  featured         Boolean        @default(false)
  rating           Float          @default(0)
  reviewCount      Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sessionTypes     SessionType[]
  availability     Availability[]
  bookings         Booking[]
  application      ProviderApplication?
}

model SessionType {
  id           String    @id @default(cuid())
  providerId   String
  provider     Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name         String
  durationMin  Int
  priceCents   Int
  description  String?
  bookings     Booking[]
}

model Availability {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
}

model Booking {
  id                    String        @id @default(cuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id])
  providerId            String
  provider              Provider      @relation(fields: [providerId], references: [id])
  sessionTypeId         String
  sessionType           SessionType   @relation(fields: [sessionTypeId], references: [id])
  scheduledAt           DateTime
  status                BookingStatus @default(PENDING)
  category              String
  topic                 String
  denominationPref      String?
  priorRabbiExperience  String?
  notes                 String?
  disclaimerAccepted    Boolean       @default(false)
  stripePaymentIntentId String?
  stripeSessionId       String?
  videoRoomUrl          String?
  rating                Int?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model ProviderApplication {
  id              String         @id @default(cuid())
  providerId      String?        @unique
  provider        Provider?      @relation(fields: [providerId], references: [id])
  fullName        String
  email           String
  phone           String?
  tier            ProviderTier
  denomination    Denomination
  ordinationBody  String?
  credentials     String
  bio             String
  specialties     String
  languages       String
  timezone        String         @default("America/New_York")
  proposedRate    Int
  references      String?
  status          ProviderStatus @default(PENDING)
  adminNotes      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model BetaSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  segment   String?
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  notes     String?
  createdAt DateTime @default(now())
}
